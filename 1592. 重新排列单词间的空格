给你一个字符串 text ，该字符串由若干被空格包围的单词组成。每个单词由一个或者多个小写英文字母组成，并且两个单词之间至少存在一个空格。题目测试用例保证 text 至少包含一个单词 。

请你重新排列空格，使每对相邻单词之间的空格数目都 相等 ，并尽可能 最大化 该数目。如果不能重新平均分配所有空格，请 将多余的空格放置在字符串末尾 ，这也意味着返回的字符串应当与原 text 字符串的长度相等。

返回 重新排列空格后的字符串 。

 

public class Solution {
    public string ReorderSpaces(string text) {

        string[] strings = text.Split(new char[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);;
        int stringsLength = 0;
        for (int i = 0; i < strings.Length; i++)
        {
            stringsLength += strings[i].Length;
        }
        int spaceLength = text.Length - stringsLength;
        int spaceNum = strings.Length > 1 ? spaceLength / (strings.Length - 1) : 0;
        string space = "";
        for(int i = 0; i < spaceNum; i++)
        {
            space += ' ';
        }
        StringBuilder result = new StringBuilder();
        for(int i = 0; i < strings.Length; i++)
        {
            result.Append(strings[i]);
            if(i != strings.Length - 1)
            {
                result.Append(space); 
            }
        }
        int spaceElse =  (strings.Length - 1) > 0 ? spaceLength % (strings.Length - 1) : spaceLength;
        for(int i = 0; i < spaceElse; i++)
        {
            result.Append(' ');
        }

        return result.ToString();
        
    }
}
